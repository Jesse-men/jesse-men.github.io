{
  "manifest_version": 3,
  "name": "Reading List — Auto-record papers",
  "version": "1.1",
  "description": "Automatically save paper URLs when you visit arXiv, IEEE Xplore, ACM DL, etc. Sync to your Reading List page.",
  "permissions": ["storage", "contextMenus", "activeTab"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "https://arxiv.org/*",
    "https://ieeexplore.ieee.org/*",
    "https://dl.acm.org/*",
    "https://*.springer.com/*",
    "https://www.sciencedirect.com/*",
    "https://jesse-men.github.io/*",
    "https://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://arxiv.org/*",
        "https://ieeexplore.ieee.org/*",
        "https://dl.acm.org/*",
        "https://*.springer.com/*",
        "https://www.sciencedirect.com/*"
      ],
      "js": ["auto-save-paper.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://jesse-men.github.io/reading_papers.html*",
        "https://localhost:*/*reading_papers*",
        "http://localhost:*/*reading_papers*"
      ],
      "js": ["send-to-page.js"],
      "run_at": "document_idle"
    }
  ]
}
